<?xml version="1.0"?>
<robot name="origins">

<material name="Metall - 1600F (heiß)">
    <color rgba="0.749 0.749 0.749 1" />
  </material>

 

  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.6" radius="0.2"/>
      </geometry>
    </visual>
  </link>

 <link name="UR10_Workbench">
    <visual>
     <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>  
            <mesh filename="../12345/UR10/UR10_WorkBench.stl"/> 
      </geometry> 
         <material name="Metall - 1600F (heiß)" />
    </visual>
  </link>

  <link name="U10_Base">
    <visual>
     <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>  
            <mesh filename="../12345/UR10/UR10_Base.stl"/>
 
      </geometry> 
         <material name="Metall - 1600F (heiß)" />
    </visual>
  </link>

<link name="First_Gelenk">
    <visual>
     <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>  
            <mesh filename="../12345/UR10_Size4_Joint_meter.stl"/>
 
      </geometry> 
     
    </visual>
  </link>

<link name="UpperArmGroup">
    <visual>
     <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>  
            <mesh filename="../12345/UR10_UpperArmGroup_meter.stl"/>
 
      </geometry> 
         <material name="Metall - 1600F (heiß)" />
    </visual>
  </link>

<link name="LowerArmGroup">
    <visual>
     <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>  
            <mesh filename="../12345/UR10_LowerArmGroup_meter.stl"/>
 
      </geometry> 
          
    </visual>
  </link>
 
<link name="Fourth_Gelenk">
    <visual>
     <origin xyz="0 0 -0.0617" rpy="0 0 0" />
      <geometry>  
            <mesh filename="../12345/UR10_Size2Joint_meter.stl"/>
 
      </geometry> 
         <material name="Metall - 1600F (heiß)" />
    </visual>
  </link>

 
<link name="Fith_Gelenk">
    <visual>
     <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>  
            <mesh filename="../12345/UR10_Size2Joint_meter.stl"/>
 
      </geometry> 
    
    </visual>
  </link>

<link name="ToolFlange">
    <visual>
     <origin xyz="0 0 0" rpy="0 -3.14592 0" />
      <geometry>  
            <mesh filename="../12345/UR10_ToolFlange_meter.stl"/>
 
      </geometry> 
     <material name="Metall - 1600F (heiß)" />
    </visual>
  </link>

 


  <joint name="BenchToBase" type="fixed">
    <parent link="base_link"/>
    <child link="UR10_Workbench"/>
    <origin xyz="0 2 0.9"/>
  </joint>

 <joint name="base_to_right_leg" type="fixed">
    <parent link="UR10_Workbench"/>
    <child link="U10_Base"/>
    <origin xyz="0.420 0.475 0"/>
  </joint>



<joint name="first_joint" type="continuous">
         <axis rpy="0 0 0" xyz="0 0 1"/>
    <parent link="U10_Base"/>
    <child link="First_Gelenk"/>
    <origin xyz="0 0 0.128"/>
  </joint>
 
<joint name="second_joint" type="continuous">
         <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="First_Gelenk"/>
    <child link="UpperArmGroup"/>
    <origin xyz="0 -0.086 0" rpy="0 0 0"/>
  </joint>


<joint name="third_joint" type="continuous">
          <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="UpperArmGroup"/>
    <child link="LowerArmGroup"/> 
 <origin xyz="0 -0.02189  0.61290" rpy="0 0 -1.5708"/>
  </joint>

<joint name="fourth_joint" type="continuous">
         <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="LowerArmGroup"/>
    <child link="Fourth_Gelenk"/>
    <origin xyz="0.05601 0 0.5716" rpy="0 -3.14592 -1.5708"/>
  </joint>

<joint name="fifth_joint" type="continuous">
         <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="Fourth_Gelenk"/>
    <child link="Fith_Gelenk"/>
    <origin xyz="0 0 -0.0617" rpy="0 -3.14592 -3.14592"/>
  </joint>

<joint name="six_joint" type="continuous">
         <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="Fith_Gelenk"/>
    <child link="ToolFlange"/>
    <origin xyz="0 -0.054 0.0617" rpy="0 0 0"/>
  </joint>

</robot>
